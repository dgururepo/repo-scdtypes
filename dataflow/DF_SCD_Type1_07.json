{
	"name": "DF_SCD_Type1_07",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_CustomerCSV_07",
						"type": "DatasetReference"
					},
					"name": "source1csvfile"
				},
				{
					"dataset": {
						"referenceName": "ds_DimCustomer_07",
						"type": "DatasetReference"
					},
					"name": "source1sqltable"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "lookup1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          CustomerID as integer,",
				"          CustomerName as string,",
				"          City as string,",
				"          Salary as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1csvfile",
				"source(output(",
				"          CustomerID as integer,",
				"          CustomerName as string,",
				"          City as string,",
				"          Salary as decimal(10,2),",
				"          LastUpdated as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1sqltable",
				"source1csvfile, source1sqltable lookup(source1csvfile@CustomerID == source1sqltable@CustomerID,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup1"
			]
		}
	}
}