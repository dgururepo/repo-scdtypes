{
	"name": "df_scdtype1_01",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_sourceexcel_scd1",
						"type": "DatasetReference"
					},
					"name": "srcexcel"
				},
				{
					"dataset": {
						"referenceName": "ds_dim_sqltable_scd1",
						"type": "DatasetReference"
					},
					"name": "srcDimsqltable"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "join1"
				}
			],
			"scriptLines": [
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> srcexcel",
				"source(output(",
				"          CustomerID as integer,",
				"          Address as string,",
				"          City as string,",
				"          Phone as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcDimsqltable",
				"srcexcel, srcDimsqltable join(ERROR_FUNCTION('') == ERROR_FUNCTION(''),",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1"
			]
		}
	}
}