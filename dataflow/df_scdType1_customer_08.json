{
	"name": "df_scdType1_customer_08",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_source_csv_param_08",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "ds_dimcustomer_sql_08",
						"type": "DatasetReference"
					},
					"name": "srcDimCustomer"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_raw_sql_08",
						"type": "DatasetReference"
					},
					"name": "sinkRaw"
				},
				{
					"dataset": {
						"referenceName": "ds_stage_sql_08",
						"type": "DatasetReference"
					},
					"name": "sinkStage"
				}
			],
			"transformations": [
				{
					"name": "drvRawAudit"
				},
				{
					"name": "drvClean"
				},
				{
					"name": "fltValidRows"
				},
				{
					"name": "drvStage"
				},
				{
					"name": "jnSCD1"
				},
				{
					"name": "drvSCDFlags"
				}
			],
			"scriptLines": [
				"source(output(",
				"          CustomerID as short,",
				"          FullName as string,",
				"          Email as string,",
				"          Phone as string,",
				"          City as string,",
				"          Segment as string,",
				"          Country as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source(output(",
				"          CustomerID as integer,",
				"          FullName as string,",
				"          Email as string,",
				"          Phone as string,",
				"          City as string,",
				"          Segment as string,",
				"          Country as string,",
				"          Region as string,",
				"          EmailDomain as string,",
				"          LastUpdated as timestamp,",
				"          CreatedDate as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcDimCustomer",
				"source1 derive(LoadDate = currentTimestamp()) ~> drvRawAudit",
				"drvRawAudit derive(CustomerID = toInteger(CustomerID),",
				"          FullName = trim(FullName),",
				"          Email = lower(trim(Email)),",
				"          Phone = regexReplace(Phone, '[^0-9]', ''),",
				"          City = initCap(trim(City)),",
				"          Segment = upper(trim(Segment)),",
				"          Country = trim(Country),",
				"          LoadDate = currentTimestamp()) ~> drvClean",
				"drvClean filter(!isNull(CustomerID) && !isNull(FullName) && length(Email) > 0) ~> fltValidRows",
				"fltValidRows derive(Region = case(Country == 'India', 'APAC', Country == 'USA' || Country == 'Canada', 'AMER', Country == 'UK', 'EMEA', 'OTHER'),",
				"          EmailDomain = split(Email,'@')[2]) ~> drvStage",
				"drvStage, srcDimCustomer join(drvClean@CustomerID == srcDimCustomer@CustomerID,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> jnSCD1",
				"jnSCD1 derive(isNew = isNull(srcDimCustomer@CustomerID)) ~> drvSCDFlags",
				"drvStage sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkRaw",
				"drvStage sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     mapColumn(",
				"          CustomerID,",
				"          FullName,",
				"          Email,",
				"          Phone,",
				"          City,",
				"          Segment,",
				"          Country,",
				"          Region,",
				"          EmailDomain,",
				"          LoadDate",
				"     )) ~> sinkStage"
			]
		}
	}
}