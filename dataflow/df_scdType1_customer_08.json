{
	"name": "df_scdType1_customer_08",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_source_csv_param_08",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "ds_dimcustomer_sql_08",
						"type": "DatasetReference"
					},
					"name": "srcDimCustomer"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_raw_sql_08",
						"type": "DatasetReference"
					},
					"name": "sinkRaw"
				},
				{
					"dataset": {
						"referenceName": "ds_stage_sql_08",
						"type": "DatasetReference"
					},
					"name": "sinkStage"
				},
				{
					"dataset": {
						"referenceName": "ds_dimcustomer_sql_08",
						"type": "DatasetReference"
					},
					"name": "sinkDimCustomer"
				}
			],
			"transformations": [
				{
					"name": "drvRawAudit"
				},
				{
					"name": "drvClean"
				},
				{
					"name": "fltValidRows"
				},
				{
					"name": "drvStage"
				},
				{
					"name": "jnSCD1"
				},
				{
					"name": "drvSCDFlags"
				},
				{
					"name": "alterRowSCD1"
				},
				{
					"name": "selFinalCols"
				}
			],
			"scriptLines": [
				"source(output(",
				"          CustomerID as short,",
				"          FullName as string,",
				"          Email as string,",
				"          Phone as string,",
				"          City as string,",
				"          Segment as string,",
				"          Country as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source(output(",
				"          CustomerID as integer,",
				"          FullName as string,",
				"          Email as string,",
				"          Phone as string,",
				"          City as string,",
				"          Segment as string,",
				"          Country as string,",
				"          Region as string,",
				"          EmailDomain as string,",
				"          LastUpdated as timestamp,",
				"          CreatedDate as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcDimCustomer",
				"source1 derive(LoadDate = currentTimestamp()) ~> drvRawAudit",
				"drvRawAudit derive(CustomerID = toInteger(CustomerID),",
				"          FullName = trim(FullName),",
				"          Email = lower(trim(Email)),",
				"          Phone = regexReplace(Phone, '[^0-9]', ''),",
				"          City = initCap(trim(City)),",
				"          Segment = upper(trim(Segment)),",
				"          Country = trim(Country),",
				"          LoadDate = currentTimestamp()) ~> drvClean",
				"drvClean filter(!isNull(CustomerID) && !isNull(FullName) && length(Email) > 0) ~> fltValidRows",
				"fltValidRows derive(Region = case(Country == 'India', 'APAC', Country == 'USA' || Country == 'Canada', 'AMER', Country == 'UK', 'EMEA', 'OTHER'),",
				"          EmailDomain = split(Email,'@')[2]) ~> drvStage",
				"drvStage, srcDimCustomer join(drvClean@CustomerID == srcDimCustomer@CustomerID,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> jnSCD1",
				"jnSCD1 derive(isNew = isNull(srcDimCustomer@CustomerID),",
				"          isChanged = !isNull(srcDimCustomer@CustomerID) &&  ( coalesce(drvClean@FullName,'') \r",
				"    != coalesce(srcDimCustomer@FullName,'')  \r",
				"    || coalesce(drvClean@Email,'') != coalesce(srcDimCustomer@Email,'')   \r",
				"    || coalesce(drvClean@Phone,'') != coalesce(srcDimCustomer@Phone,'')  \r",
				"    || coalesce(drvClean@City,'') != coalesce(srcDimCustomer@City,'')   \r",
				"    || coalesce(drvClean@Segment,'') != coalesce(srcDimCustomer@Segment,'')  ),",
				"          isUnchanged = !isNull(srcDimCustomer@CustomerID) &&  !( coalesce(drvClean@FullName,'') != coalesce(srcDimCustomer@FullName,'')  || coalesce(drvClean@Email,'') != coalesce(srcDimCustomer@Email,'')   || coalesce(drvClean@Phone,'') != coalesce(srcDimCustomer@Phone,'')   || coalesce(drvClean@City,'') != coalesce(srcDimCustomer@City,'')   || coalesce(drvClean@Segment,'') != coalesce(srcDimCustomer@Segment,'')  ),",
				"          LastUpdated = iif((isNull(srcDimCustomer@CustomerID)) || (!isNull(srcDimCustomer@CustomerID) && \r",
				"(\r",
				"coalesce(drvClean@FullName,'') != coalesce(srcDimCustomer@FullName,'')\r",
				" || coalesce(drvClean@Email,'') != coalesce(srcDimCustomer@Email,'') \r",
				" || coalesce(drvClean@Phone,'') != coalesce(srcDimCustomer@Phone,'') \r",
				" || coalesce(drvClean@City,'') != coalesce(srcDimCustomer@City,'') \r",
				" || coalesce(drvClean@Segment,'') != coalesce(srcDimCustomer@Segment,'')\r",
				" )), currentTimestamp(), \r",
				" LastUpdated)) ~> drvSCDFlags",
				"drvSCDFlags alterRow(insertIf(isNew == true()),",
				"     upsertIf(isChanged == true())) ~> alterRowSCD1",
				"alterRowSCD1 select(mapColumn(",
				"          CustomerID = drvClean@CustomerID,",
				"          FullName = drvClean@FullName,",
				"          Email = drvClean@Email,",
				"          Phone = drvClean@Phone,",
				"          City = drvClean@City,",
				"          Segment = drvClean@Segment,",
				"          Country = drvClean@Country,",
				"          LoadDate,",
				"          Region = drvStage@Region,",
				"          EmailDomain = drvStage@EmailDomain,",
				"          CustomerID = srcDimCustomer@CustomerID,",
				"          FullName = srcDimCustomer@FullName,",
				"          Email = srcDimCustomer@Email,",
				"          Phone = srcDimCustomer@Phone,",
				"          City = srcDimCustomer@City,",
				"          Segment = srcDimCustomer@Segment,",
				"          Country = srcDimCustomer@Country,",
				"          Region = srcDimCustomer@Region,",
				"          EmailDomain = srcDimCustomer@EmailDomain,",
				"          LastUpdated,",
				"          CreatedDate,",
				"          isNew,",
				"          isChanged,",
				"          isUnchanged",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selFinalCols",
				"drvStage sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkRaw",
				"drvStage sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     mapColumn(",
				"          CustomerID,",
				"          FullName,",
				"          Email,",
				"          Phone,",
				"          City,",
				"          Segment,",
				"          Country,",
				"          Region,",
				"          EmailDomain,",
				"          LoadDate",
				"     )) ~> sinkStage",
				"selFinalCols sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['CustomerID'],",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkDimCustomer"
			]
		}
	}
}