{
	"name": "DF_SCD_Type1_01",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_sourceexcel_scd1_04",
						"type": "DatasetReference"
					},
					"name": "srcexcel"
				},
				{
					"dataset": {
						"referenceName": "ds_dim_sqltable_scd1_04",
						"type": "DatasetReference"
					},
					"name": "srcDimsqltable"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_dim_sqltable_scd1_04",
						"type": "DatasetReference"
					},
					"name": "DimCustomerType1"
				}
			],
			"transformations": [
				{
					"name": "join1"
				},
				{
					"name": "derlastupdateddate"
				},
				{
					"name": "alterRow1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          CustomerID as short,",
				"          Address as string,",
				"          City as string,",
				"          Phone as long",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> srcexcel",
				"source(output(",
				"          CustomerID as integer,",
				"          Address as string,",
				"          City as string,",
				"          Phone as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcDimsqltable",
				"srcexcel, srcDimsqltable join(srcexcel@CustomerID == srcDimsqltable@CustomerID,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1 derive(LastUpdatedDate = currentTimestamp()) ~> derlastupdateddate",
				"derlastupdateddate alterRow(upsertIf(true())) ~> alterRow1",
				"alterRow1 select(mapColumn(",
				"          CustomerID = srcexcel@CustomerID,",
				"          Address = srcexcel@Address,",
				"          City = srcexcel@City,",
				"          Phone = srcexcel@Phone,",
				"          CustomerID = srcDimsqltable@CustomerID,",
				"          Address = srcDimsqltable@Address,",
				"          City = srcDimsqltable@City,",
				"          Phone = srcDimsqltable@Phone,",
				"          LastUpdatedDate",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['CustomerID','Address','City','Phone','LastUpdatedDate'],",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> DimCustomerType1"
			]
		}
	}
}